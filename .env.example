# Each component has a local default and an Azure backend. Set the Azure values
# to switch a component over; leave them blank to run fully locally.

VECTOR_BACKEND=local        # local | azure_search
ANSWER_BACKEND=extractive   # extractive | azure_openai
DOC_BACKEND=local           # local | azure_blob
FEEDBACK_BACKEND=local      # local | cosmos
TOP_K=4

# Azure AI Search
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_KEY=
AZURE_SEARCH_INDEX=documents

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o-mini

# Azure Blob (document store) — point at Azurite for local testing
AZURE_STORAGE_CONNECTION_STRING=
DOC_BLOB_CONTAINER=documents

# Azure Cosmos DB (feedback store)
COSMOS_CONNECTION_STRING=
COSMOS_DATABASE=docintel
COSMOS_CONTAINER=feedback
